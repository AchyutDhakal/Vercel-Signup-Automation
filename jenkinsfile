pipeline {
    agent any

    environment{
        EMAIL_ADDRESS = credentials('email-address')
        EMAIL_PASSWORD = credentials('email-password')
    }

    stages {
        stage('Install Dependencies') {
            steps {
                sh 'pip3 install -r requirements.txt'
            }
        }

        stage('Run Tests') {
            steps {
                sh 'python3 -m pytest'
            }
        }
    }
}